# ==============================================
# Agentic Research Copilot — Environment Config
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Required ---
# Get your API key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Optional Overrides ---
# Uncomment any line below to override the default from config/settings.py

# LLM model (default: claude-3-haiku-20240307)
# LLM_MODEL=claude-3-haiku-20240307

# Number of chunks to retrieve per query (default: 5)
# TOP_K=5

# Confidence threshold — below this the agent abstains (default: 0.7)
# CONFIDENCE_THRESHOLD=0.7

# Maximum multi-hop retrieval iterations (default: 3)
# MAX_HOPS=3

# Embedding model — any sentence-transformers model (default: all-MiniLM-L6-v2)
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunk size / overlap for document splitting (default: 1000 / 200)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
